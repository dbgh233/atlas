# =============================================================================
# Atlas Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values for local development.

# --- GoHighLevel ---
GHL_API_KEY=pit-XXXX                    # Agency PIT key
GHL_LOCATION_ID=l39XXt9HcdLTsuqTind6    # AHG location (default)
GHL_PIPELINE_ID=V6mwUqamI0tGUm1GDvKD   # Onboarding pipeline (default)

# --- Calendly ---
CALENDLY_API_KEY=eyJraWQ...             # Personal Access Token

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-XXXX              # Bot User OAuth Token
SLACK_SIGNING_SECRET=XXXX              # App Credentials > Signing Secret
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...  # Optional: incoming webhook

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-api03-XXXX    # Claude API key

# --- Database ---
DATABASE_PATH=/app/data/atlas.db       # SQLite path (Railway volume: /app/data/)

# --- Logging ---
LOG_JSON_FORMAT=true                   # true for Railway, false for local dev
LOG_LEVEL=INFO                         # DEBUG, INFO, WARNING, ERROR
